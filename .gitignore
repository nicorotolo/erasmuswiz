# Fonti ufficiali (PDF/ODS del bando): restano solo in locale
fonti/

# File di lavoro locali
.claude/
*.txt

# Pipeline mappatura: file effimeri (INPUT/OUTPUT). Le FONTI-*.json si committano.
batch/INPUT.json
batch/OUTPUT.json

# Artefatti accidentali da run AI (nomi anomali tipo b.comp.ordine, m.requisitoLingua.length)
*.ordine
*.length
contesto
ZAINO.checklist
chatgpt-project/

# Dipendenze Node: mai committare, si rigenerano con npm install
node_modules/

# Backup locali creati durante le sessioni di sync
_backup-*/

# Artefatti da comandi rotti (log di errore o file dal nome anomalo)
# NOTA: "!" e "[" sono caratteri speciali per git anche dentro .gitignore,
# quindi qui vanno sempre scritti preceduti da "\" per essere presi alla lettera.
nuldel
{,-
{,+
{,
{
({
5)
main
new
Stato
utente
\!(ZAINO.checklist
\!ZAINO.checklist\[v.id\]
`${a.nome}
b.comp.ordine
m.requisitoLingua.length
togglePreferita(meta.id))

# Difesa generica: qualunque file che inizia con un carattere di sintassi
# shell (segno tipico dei residui di comandi rotti degli agenti AI)
\!*
`*
{*
(*
\[*
$*
